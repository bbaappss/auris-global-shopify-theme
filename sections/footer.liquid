<footer class="auris-footer full-width">
  <div class="auris-container auris-footer__inner">
    <div>
      <div class="auris-footer__brand-name">
        {{ section.settings.brand_name | default: shop.name }}
      </div>
      {% if section.settings.brand_text != blank %}
        <p class="auris-footer__brand-text">{{ section.settings.brand_text }}</p>
      {% endif %}
    </div>

    <nav class="auris-footer__nav">
      {% for link in section.settings.menu.links %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}
    </nav>

    <div class="auris-footer__legal">
      &copy; {{ 'now' | date: '%Y' }} {{ section.settings.legal_name | default: shop.name }}.
      <br>
      <span class="auris-caps">{{ section.settings.rights_text | default: 'All rights reserved' }}</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "default": "Auris"
    },
    {
      "type": "textarea",
      "id": "brand_text",
      "label": "Brand description",
      "default": "A premium sports holding company. Hospitality, investment, access."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "text",
      "id": "legal_name",
      "label": "Legal entity name",
      "default": "Auris Global, LLC"
    },
    {
      "type": "text",
      "id": "rights_text",
      "label": "Rights line",
      "default": "All rights reserved"
    }
  ]
}
{% endschema %}
