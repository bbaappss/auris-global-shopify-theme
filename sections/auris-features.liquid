{%- liquid
  assign bg = 'var(--stone)'
  if section.settings.background == 'ivory'
    assign bg = 'var(--ivory)'
  elsif section.settings.background == 'navy'
    assign bg = 'var(--navy)'
  endif
-%}
<section class="auris-section full-width" style="background-color: {{ bg }};">
  <div class="auris-container">
    {% if section.settings.eyebrow != blank %}
      <div class="auris-eyebrow" style="text-align: center; color: var(--oxblood);">
        {{ section.settings.eyebrow }}
      </div>
    {% endif %}

    <div class="auris-features__grid">
      {% for block in section.blocks %}
        <div class="auris-feature" {{ block.shopify_attributes }}>
          {% if block.settings.number != blank %}
            <div class="auris-feature__num">{{ block.settings.number }}</div>
          {% endif %}
          <h3 class="auris-feature__head">{{ block.settings.heading }}</h3>
          <p class="auris-feature__body">{{ block.settings.body }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Auris features",
  "settings": [
    {
      "type": "select",
      "id": "background",
      "label": "Background",
      "options": [
        { "value": "stone", "label": "Stone" },
        { "value": "ivory", "label": "Ivory" },
        { "value": "navy", "label": "Navy" }
      ],
      "default": "stone"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "What to Expect"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Curated, Not Crowded"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body",
          "default": "Every Auris Society gathering is built for a small group. The intimacy is the point."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Auris features",
      "blocks": [
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" }
      ]
    }
  ]
}
{% endschema %}
