<section class="auris-hero full-width">
  {% if section.settings.image %}
    <div class="auris-hero__media">
      {{
        section.settings.image
        | image_url: width: 2400
        | image_tag: loading: 'eager', sizes: '100vw', widths: '600, 1000, 1500, 2000, 2400'
      }}
    </div>
    <div class="auris-hero__overlay"></div>
  {% elsif section.settings.image_asset != blank %}
    <div class="auris-hero__media">
      <img src="{{ section.settings.image_asset | asset_url }}" alt="{{ section.settings.heading | escape }}" width="1920" height="1080" loading="eager">
    </div>
    <div class="auris-hero__overlay"></div>
  {% endif %}

  <div class="auris-container auris-hero__content auris-fade">
    {% if section.settings.eyebrow != blank %}
      <div class="auris-eyebrow">{{ section.settings.eyebrow }}</div>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h1 class="auris-hero__title {% if section.settings.heading_size == 'sub' %}auris-hero__title--sub{% endif %}" style="margin-top: 2rem;">
        {{ section.settings.heading }}
      </h1>
    {% endif %}

    {% if section.settings.tagline != blank %}
      <div class="auris-hero__tagline">
        <span class="auris-hairline" style="width: 5rem;"></span>
        <p>{{ section.settings.tagline }}</p>
      </div>
    {% endif %}

    {% if section.settings.lede != blank %}
      <p class="auris-hero__lede">{{ section.settings.lede }}</p>
    {% endif %}

    {% if section.settings.button_label != blank %}
      <div style="margin-top: 3rem;">
        <a href="{{ section.settings.button_url | default: '#' }}" class="auris-btn">
          {{ section.settings.button_label }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Auris hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "image_asset",
      "label": "Fallback image asset filename",
      "info": "Used only when no Background image is chosen. e.g. spirit-stadium.jpg"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Est. MMXXVI"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Auris"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "display", "label": "Display (home)" },
        { "value": "sub", "label": "Sub (interior pages)" }
      ],
      "default": "display"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Italic tagline",
      "default": "Listening is the edge."
    },
    {
      "type": "textarea",
      "id": "lede",
      "label": "Lede paragraph"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Auris hero"
    }
  ]
}
{% endschema %}
