{% comment %}
  Auris cart — /cart page styled to match the theme, with an empty state.
  https://shopify.dev/docs/storefronts/themes/architecture/templates/cart
{% endcomment %}

<section class="auris-cart full-width auris-bg-ivory">
  <div class="auris-container">
    <div class="auris-cart__head">
      <div class="auris-eyebrow" style="color: var(--aurum);">Auris</div>
      <h1 class="auris-cart__title">{{ section.settings.heading | default: 'Cart' }}</h1>
    </div>

    {% if cart.item_count == 0 %}
      <div class="auris-cart__empty">
        <p class="auris-cart__empty-text">
          {{ section.settings.empty_text | default: 'Your cart is empty.' }}
        </p>
        <a href="{{ section.settings.empty_link_url | default: routes.root_url }}" class="auris-btn">
          {{ section.settings.empty_link_label | default: 'Explore Auris' }}
        </a>
      </div>
    {% else %}
      <form action="{{ routes.cart_url }}" method="post" class="auris-cart__form">
        <ul class="auris-cart__items">
          {% for item in cart.items %}
            <li class="auris-cart__item">
              <a href="{{ item.url }}" class="auris-cart__thumb">
                {% if item.image %}
                  {%- assign item_alt = item.product.title | escape -%}
                  {{ item.image | image_url: width: 200 | image_tag: loading: 'lazy', alt: item_alt, widths: '120, 200, 300' }}
                {% endif %}
              </a>

              <div class="auris-cart__info">
                <a href="{{ item.url }}" class="auris-cart__name">{{ item.product.title }}</a>
                {% unless item.variant.title contains 'Default' %}
                  <div class="auris-cart__variant">{{ item.variant.title }}</div>
                {% endunless %}
                {% if item.selling_plan_allocation %}
                  <div class="auris-cart__variant">{{ item.selling_plan_allocation.selling_plan.name }}</div>
                {% endif %}
                <div class="auris-cart__unit">{{ item.final_price | money }}</div>
                <a href="{{ item.url_to_remove }}" class="auris-cart__remove">{{ 'cart.remove' | t }}</a>
              </div>

              <div class="auris-cart__qty">
                <label class="auris-cart__qty-label" for="updates_{{ item.key }}">
                  {{ 'cart.update' | t }}
                </label>
                <input
                  type="number"
                  id="updates_{{ item.key }}"
                  name="updates[]"
                  value="{{ item.quantity }}"
                  min="0"
                  inputmode="numeric"
                  class="auris-cart__qty-input"
                >
              </div>

              <div class="auris-cart__line-price">{{ item.final_line_price | money }}</div>
            </li>
          {% endfor %}
        </ul>

        <div class="auris-cart__footer">
          <div class="auris-cart__subtotal">
            <span class="auris-eyebrow" style="color: var(--carbon); opacity: 0.6;">Subtotal</span>
            <span class="auris-cart__subtotal-value">{{ cart.total_price | money }}</span>
          </div>

          <div class="auris-cart__actions">
            <button type="submit" name="update" class="auris-cart__update">{{ 'cart.update' | t }}</button>
            <button type="submit" name="checkout" class="auris-btn">{{ 'cart.checkout' | t }}</button>
          </div>

          <p class="auris-cart__note">Taxes and shipping calculated at checkout.</p>
        </div>
      </form>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "t:general.cart",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Cart"
    },
    {
      "type": "text",
      "id": "empty_text",
      "label": "Empty cart text",
      "default": "Your cart is empty."
    },
    {
      "type": "text",
      "id": "empty_link_label",
      "label": "Empty cart button label",
      "default": "Explore Auris"
    },
    {
      "type": "url",
      "id": "empty_link_url",
      "label": "Empty cart button link"
    }
  ]
}
{% endschema %}
