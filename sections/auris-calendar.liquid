<section class="auris-section full-width auris-bg-ivory">
  <div class="auris-container">
    <ul class="auris-calendar__list">
      {% for block in section.blocks %}
        <li class="auris-calendar__item" {{ block.shopify_attributes }}>
          <div>
            <div class="auris-calendar__year">{{ block.settings.year }}</div>
            {% if block.settings.status != blank %}
              <div class="auris-calendar__status">{{ block.settings.status }}</div>
            {% endif %}
          </div>
          <div>
            <h2 class="auris-calendar__name">{{ block.settings.title }}</h2>
            {% if block.settings.city != blank %}
              <div class="auris-calendar__city">{{ block.settings.city }}</div>
            {% endif %}
            {% if block.settings.blurb != blank %}
              <p class="auris-calendar__blurb">{{ block.settings.blurb }}</p>
            {% endif %}
          </div>
          {%- liquid
            assign product = block.settings.product
            assign btn_url = block.settings.button_url | default: '#'
            assign btn_label = block.settings.button_label
            if product != blank
              assign btn_url = product.url
              if btn_label == blank
                assign btn_label = 'Reserve'
              endif
            endif
          -%}
          <div class="auris-calendar__action">
            {% if product != blank and product.available %}
              <div class="auris-calendar__price">{{ product.price | money }}</div>
            {% elsif product != blank %}
              <div class="auris-calendar__price auris-calendar__price--soldout">Sold out</div>
            {% endif %}
            {% if btn_label != blank %}
              <a href="{{ btn_url }}" class="auris-btn">{{ btn_label }}</a>
            {% endif %}
          </div>
        </li>
      {% endfor %}
    </ul>

    {% if section.settings.footnote != blank %}
      <p class="auris-calendar__foot">{{ section.settings.footnote }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Auris calendar",
  "settings": [
    {
      "type": "textarea",
      "id": "footnote",
      "label": "Footnote",
      "default": "Dates and venues confirmed closer to each gathering. Society members are notified first."
    }
  ],
  "blocks": [
    {
      "type": "event",
      "name": "Event",
      "settings": [
        {
          "type": "text",
          "id": "year",
          "label": "Year",
          "default": "2026"
        },
        {
          "type": "text",
          "id": "status",
          "label": "Date / status",
          "default": "Aug 30 – Sep 13"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "US Open"
        },
        {
          "type": "text",
          "id": "city",
          "label": "City",
          "default": "New York City"
        },
        {
          "type": "textarea",
          "id": "blurb",
          "label": "Description",
          "default": "A late-summer evening at Flushing Meadows — premium courtside hospitality around the season's defining tennis fortnight."
        },
        {
          "type": "product",
          "id": "product",
          "label": "Linked product",
          "info": "Optional. When set, the button links to this product and shows its live price."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Register Interest"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button link",
          "info": "Used only when no product is linked."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Auris calendar",
      "blocks": [
        { "type": "event" },
        { "type": "event" },
        { "type": "event" },
        { "type": "event" }
      ]
    }
  ]
}
{% endschema %}
