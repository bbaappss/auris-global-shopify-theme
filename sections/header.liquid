<header class="auris-header" data-auris-header>
  <div class="auris-container auris-header__inner">
    <a href="{{ routes.root_url }}" class="auris-header__logo">
      {{ section.settings.logo_text | default: shop.name }}
    </a>

    <nav class="auris-header__nav">
      {% for link in section.settings.menu.links %}
        <a href="{{ link.url }}" class="auris-header__link">{{ link.title }}</a>
      {% endfor %}

      <a href="{{ routes.cart_url }}" class="auris-header__link">
        <span>{{ section.settings.cart_label | default: 'Cart' }}</span>
        <span class="auris-header__cart-count">({{ cart.item_count }})</span>
      </a>
    </nav>

    <button class="auris-header__toggle" aria-label="Menu" data-auris-toggle aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="auris-header__mobile" data-auris-mobile>
    <div class="auris-header__mobile-inner">
      {% for link in section.settings.menu.links %}
        <a href="{{ link.url }}" class="auris-header__link">{{ link.title }}</a>
      {% endfor %}
      <a href="{{ routes.cart_url }}" class="auris-header__link">
        {{ section.settings.cart_label | default: 'Cart' }} ({{ cart.item_count }})
      </a>
    </div>
  </div>
</header>

<script>
  (function () {
    var header = document.querySelector('[data-auris-header]');
    if (!header) return;
    var onScroll = function () {
      header.classList.toggle('is-scrolled', window.scrollY > 12);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    var toggle = header.querySelector('[data-auris-toggle]');
    var mobile = header.querySelector('[data-auris-mobile]');
    if (toggle && mobile) {
      toggle.addEventListener('click', function () {
        var open = mobile.classList.toggle('is-open');
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
    }
  })();
</script>

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "Auris"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "text",
      "id": "cart_label",
      "label": "Cart label",
      "default": "Cart"
    },
    {
      "type": "text",
      "id": "account_label",
      "label": "Account label",
      "default": "Account"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
